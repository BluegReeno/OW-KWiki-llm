# Optional: model alias passed to `claude -p --model` (e.g. "sonnet", "opus"). Unset uses the CLI's default.
CLAUDE_MODEL=

# Optional: override if `claude` isn't on PATH for the process running this pipeline
CLAUDE_BIN=claude

# No API key needed at all: poll_rss.py reads the public offshoreWIND.biz RSS
# feed (no account), and the wiki-curator agent runs via `claude -p` (see
# wiki_agent.py), authenticated with your existing Claude Code login
# (Max/Pro subscription usage).
