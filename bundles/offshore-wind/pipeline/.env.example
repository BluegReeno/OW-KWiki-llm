# Get this from https://console.agentmail.to
AGENTMAIL_API_KEY=

# Optional: fixed inbox username -> becomes <this>@agentmail.to. If unset, AgentMail assigns a random one.
AGENTMAIL_INBOX_USERNAME=offshore-wind-digest

# Optional: seconds between polls
POLL_INTERVAL_SECONDS=30

# Optional: model alias passed to `claude -p --model` (e.g. "sonnet", "opus"). Unset uses the CLI's default.
CLAUDE_MODEL=

# Optional: override if `claude` isn't on PATH for the process running this pipeline
CLAUDE_BIN=claude

# No ANTHROPIC_API_KEY needed: the wiki-curator agent runs via `claude -p`
# (see wiki_agent.py), authenticated with your existing Claude Code login
# (Max/Pro subscription usage), not a separate Console API key.
# Make sure `claude` is logged in: run `claude` once interactively if you
# haven't already, or `claude auth login`.
